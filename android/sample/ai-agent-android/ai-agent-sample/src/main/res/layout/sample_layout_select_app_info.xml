<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tool="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="40dp"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clAppInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:adjustViewBounds="true"
                android:layout_marginTop="8dp"
                android:src="@drawable/logo_dark"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Region -->
            <TextView
                android:id="@+id/tvRegion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="@string/sample_text_region"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivLogo" />

            <Spinner
                android:id="@+id/sRegion"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_spinner_dark"
                android:entries="@array/sb_regions"
                android:spinnerMode="dropdown"
                android:popupBackground="@color/dark_input"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvRegion" />

            <!-- App ID -->
            <TextView
                android:id="@+id/tvAppId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/sample_text_app_id"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sRegion" />

            <EditText
                android:id="@+id/etAppId"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field_dark"
                android:inputType="text"
                android:padding="14dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvAppId"
                tool:text="5B306480-5E40-40BA-A702-EA0935B4898D" />

            <!-- AI Agent ID -->
            <TextView
                android:id="@+id/tvAIAgentId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/sample_text_ai_agent_id"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etAppId" />

            <EditText
                android:id="@+id/etAIAgentId"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field_dark"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:padding="14dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvAIAgentId"
                tool:text="4131e150-1845-417a-976f-15d262c66ad1" />

            <!-- Save Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_button_primary"
                android:text="@string/sample_text_save"
                android:textAllCaps="false"
                android:textColor="@color/dark_bg"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etAIAgentId" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Powered by - pinned to bottom -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:paddingBottom="16dp"
        android:text="@string/sample_text_powered_by"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:letterSpacing="0.02" />

</FrameLayout>
